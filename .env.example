# =============================================================================
# Xase OS — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control — it is listed in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (required)
# -----------------------------------------------------------------------------
# PostgreSQL connection string.
# Local dev:  postgres://postgres:postgres@localhost:5432/xaseos
# Docker:     postgres://postgres:postgres@db:5432/xaseos
# Production: postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL="postgres://user:password@host:port/database?sslmode=require"

# -----------------------------------------------------------------------------
# AUTHENTICATION (required)
# -----------------------------------------------------------------------------
# Random string, min 32 characters. Used to sign JWT auth cookies.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-with-a-random-secret-min-32-chars"

# -----------------------------------------------------------------------------
# ENCRYPTION (required)
# -----------------------------------------------------------------------------
# Random string, min 32 characters. Used to encrypt stored API keys in the DB.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="replace-with-a-random-key-min-32-chars!!"

# -----------------------------------------------------------------------------
# APPLICATION URL (optional)
# -----------------------------------------------------------------------------
# Full URL the app is served from. Used for CORS and absolute link generation.
# Defaults to http://localhost:3002 in development.
NEXT_PUBLIC_APP_URL="http://localhost:3002"

# -----------------------------------------------------------------------------
# LLM PROVIDER API KEYS (optional — stored per-user in the DB)
# -----------------------------------------------------------------------------
# These are only needed for local scripts/tests that call providers directly.
# In-app: users enter their own keys via the Settings page (encrypted at rest).

# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."
# GOOGLE_API_KEY="AIza..."
# GROQ_API_KEY="gsk_..."
# XAI_API_KEY="xai-..."

# Ollama — local LLM server (no API key required)
# OLLAMA_BASE_URL="http://localhost:11434"

# -----------------------------------------------------------------------------
# HUGGINGFACE (optional — for dataset push-to-hub)
# -----------------------------------------------------------------------------
# Personal access token with write access to your HF account.
# HUGGINGFACE_TOKEN="hf_..."

# -----------------------------------------------------------------------------
# TELEMETRY (optional)
# -----------------------------------------------------------------------------
# Set to "1" to opt out of anonymous usage analytics (not yet implemented).
# XASEOS_TELEMETRY_DISABLED="1"
